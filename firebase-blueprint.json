{
  "entities": {
    "product": {
      "title": "Product",
      "description": "A construction material product sold in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "unit": { "type": "string" },
        "image": { "type": "string" },
        "brand": { "type": "string" },
        "rating": { "type": "number" },
        "description": { "type": "string" },
        "id": { "type": "string" }
      },
      "required": ["name", "category", "price", "unit", "image", "brand"]
    },
    "admin": {
      "title": "Admin",
      "description": "User with administrative privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      }
    },
    "settings": {
      "title": "Store Settings",
      "description": "Global configuration for the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "fullName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "whatsappDisplay": { "type": "string" },
        "address": { "type": "string" },
        "hours": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "cityYear": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "recipient": { "type": "string" }
      },
      "required": ["userId", "message", "createdAt", "read", "recipient"]
    },
    "review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "product",
      "description": "Collection of all products in the store"
    },
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "Collection of administrator UIDs"
    },
    "/settings/{settingId}": {
      "schema": "settings",
      "description": "Global store settings"
    },
    "/notifications/{notificationId}": {
      "schema": "notification",
      "description": "Notifications for users"
    },
    "/reviews/{reviewId}": {
      "schema": "review",
      "description": "Product reviews"
    }
  }
}
